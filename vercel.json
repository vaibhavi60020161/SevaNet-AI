{
  "version": 2,
  "functions": {
    "server/server.ts": {
      "runtime": "vercel-node@latest"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server/server.ts"
    }
  ]
}
